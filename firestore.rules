rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a real app, we check a collection or claim. 
      // For this prototype, we'll allow the creator email or checks against a settings doc.
      // But for simplicity in this prompt, let's allow authenticated users to read and 
      // specific users to write (we can simulate admin by checking a known email)
      return isSignedIn() && (
        request.auth.token.email == 'ridhoridhoaji7@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // News & Information
    match /news/{newsId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if isAdmin();
    }

    // Members
    match /members/{memberId} {
      allow read: if true; // Public directory
      allow create, update, delete: if isAdmin();
    }

    // Organization Content
    match /orgContent/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin list (bootstrap)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
